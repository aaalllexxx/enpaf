    "features": [
        {
            "key": "NFC",
            "required": false
        },
        {
            "key": "GYROSCOPE",
            "required": false
        },
        {
            "key": "ACCELEROMETER",
            "required": false
        },
        {
            "key": "CAMERA_FRONT",
            "required": false
        },
        {
            "key": "CAMERA",
            "required": false
        },
        {
            "key": "CAMERA_AUTOFOCUS",
            "required": false
