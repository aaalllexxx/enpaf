# =============================================================================
# ENPAF — nginx reverse-proxy config for enpaf.labunit.ru
#
# This is the TLS + security-headers layer that sits in FRONT of the Docker
# container (which serves the static site with Python http.server on :5000).
#
# Deploy on the server:  copy to /etc/nginx/sites-available/enpaf.labunit.ru,
#   symlink into sites-enabled, then:  nginx -t && systemctl reload nginx
#
# TLS certs here assume certbot / Let's Encrypt. Adjust paths if different.
# =============================================================================

# --- HTTP :80 → redirect everything to HTTPS ---------------------------------
server {
    listen 80;
    listen [::]:80;
    server_name enpaf.labunit.ru;

    # Allow ACME http-01 challenges (certbot renewals) without a redirect.
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# --- HTTPS :443 --------------------------------------------------------------
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name enpaf.labunit.ru;

    # --- TLS ---
    ssl_certificate     /etc/letsencrypt/live/enpaf.labunit.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/enpaf.labunit.ru/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_stapling        on;
    ssl_stapling_verify on;

    # =========================================================================
    # SECURITY HEADERS  — this is what removes the real "not fully secure" gap.
    # =========================================================================

    # HSTS: after the first visit, browsers refuse plain HTTP for 2 years.
    # Only enable "preload" once you're sure HTTPS will stay on for good.
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;

    # Don't let the page be framed (clickjacking protection).
    add_header X-Frame-Options "SAMEORIGIN" always;

    # Stop MIME-type sniffing.
    add_header X-Content-Type-Options "nosniff" always;

    # Referrer privacy.
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Lock down powerful browser features the site doesn't use.
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()" always;

    # Content Security Policy — allows self + Google Fonts (used by the page).
    add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests" always;

    # --- Proxy to the Docker container (Python http.server on :5000) ---
    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
